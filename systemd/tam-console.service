[Unit]
Description=TAM Console
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=ubuntu
Group=ubuntu
WorkingDirectory=/opt/tam-console
EnvironmentFile=-/opt/tam-console/.env
ExecStart=/usr/bin/python3 /opt/tam-console/app.py
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target
